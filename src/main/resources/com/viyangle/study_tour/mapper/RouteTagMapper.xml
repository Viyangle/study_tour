<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.viyangle.study_tour.mapper.RouteTagMapper">

    <insert id="insert" parameterType="com.viyangle.study_tour.pojo.RouteTag">
        insert into route_tags
        (route_id, tag_id)
        values
        (#{routeId}, #{tagId})
    </insert>

    <delete id="deleteById">
        delete from route_tags
        where route_id = #{routeId} and tag_id = #{tagId}
    </delete>

    <select id="selectById" resultType="com.viyangle.study_tour.pojo.RouteTag">
        select route_id, tag_id
        from route_tags
        where route_id = #{routeId} and tag_id = #{tagId}
    </select>

    <select id="selectAll" resultType="com.viyangle.study_tour.pojo.RouteTag">
        select route_id, tag_id
        from route_tags
    </select>

</mapper>
