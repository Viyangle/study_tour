<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.viyangle.study_tour.mapper.RouteMapper">

    <insert id="insert" parameterType="com.viyangle.study_tour.pojo.Route"
            useGeneratedKeys="true" keyProperty="id">
        insert into routes(created_at) VALUES (now())
    </insert>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from routes where id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultType="com.viyangle.study_tour.pojo.Route">
        select id, created_at
        from routes
        where id = #{id}
    </select>

    <select id="selectAll" resultType="com.viyangle.study_tour.pojo.Route">
        select id, created_at
        from routes
    </select>

</mapper>
