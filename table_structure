-- 1) 账户（用户/领队共用，role 区分）
CREATE TABLE accounts (
                          id BIGINT PRIMARY KEY AUTO_INCREMENT,
                          role ENUM('USER','LEADER') NOT NULL DEFAULT 'USER',
                          username VARCHAR(50) NOT NULL UNIQUE,
                          phone VARCHAR(20) UNIQUE,
                          password_hash VARCHAR(255) NOT NULL,
                          region_code VARCHAR(20) NOT NULL,        -- 注册时选择地区
                          avatar_url VARCHAR(255),
                          status TINYINT NOT NULL DEFAULT 1,       -- 1正常 0禁用
                          created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                          updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 2) 领队扩展信息
CREATE TABLE leader_profiles (
                                 account_id BIGINT PRIMARY KEY,
                                 intro VARCHAR(500),
                                 years_of_exp INT DEFAULT 0,
                                 base_region_code VARCHAR(20),
                                 total_rating INT DEFAULT 0.00,  -- 综合评分（可冗余）
                                 rating_count INT DEFAULT 0,
                                 FOREIGN KEY (account_id) REFERENCES accounts(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 3) tag 字典
CREATE TABLE tags (
                      id BIGINT PRIMARY KEY AUTO_INCREMENT,
                      name VARCHAR(50) NOT NULL UNIQUE,
                      type ENUM('INTEREST','ROUTE_STYLE','CROWD','SCENIC') NOT NULL DEFAULT 'INTEREST',
                      created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 4) 用户偏好 tag（注册时选）
CREATE TABLE account_tag_prefs (
                                   account_id BIGINT NOT NULL,
                                   tag_id BIGINT NOT NULL,
                                   weight TINYINT NOT NULL DEFAULT 1,        -- 偏好强度 1-5
                                   PRIMARY KEY (account_id, tag_id),
                                   FOREIGN KEY (account_id) REFERENCES accounts(id),
                                   FOREIGN KEY (tag_id) REFERENCES tags(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 5) 路线（手动/历史推荐/AI 生成）
CREATE TABLE routes (
                        id BIGINT PRIMARY KEY AUTO_INCREMENT,
                        creator_account_id BIGINT NOT NULL,
                        title VARCHAR(100) NOT NULL,
                        region_code VARCHAR(20) NOT NULL,
                        days INT NOT NULL,
                        outline TEXT,                              -- 简要描述
                        detail_json JSON,                          -- 行程详情（前期可先 JSON）
                        created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                        FOREIGN KEY (creator_account_id) REFERENCES accounts(id),
                        INDEX idx_route_region(region_code),
                        INDEX idx_route_creator(creator_account_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 6) 路线-tag
CREATE TABLE route_tags (
                            route_id BIGINT NOT NULL,
                            tag_id BIGINT NOT NULL,
                            weight TINYINT NOT NULL DEFAULT 1,
                            PRIMARY KEY (route_id, tag_id),
                            FOREIGN KEY (route_id) REFERENCES routes(id),
                            FOREIGN KEY (tag_id) REFERENCES tags(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 7) 拼单项目（进行中项目）
CREATE TABLE projects (
                          id BIGINT PRIMARY KEY AUTO_INCREMENT,
                          route_id BIGINT NOT NULL,
                          owner_account_id BIGINT NOT NULL,         -- 发起用户
                          leader_account_id BIGINT NULL,            -- 接单成功后填充
                          title VARCHAR(100) NOT NULL,
                          departure_date DATE,
                          max_members INT NOT NULL DEFAULT 4,
                          current_members INT NOT NULL DEFAULT 1,
                          status ENUM('OPEN','MATCHING','CONFIRMED','IN_PROGRESS','DONE','CANCELLED') NOT NULL DEFAULT 'OPEN',
                          created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                          updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                          FOREIGN KEY (route_id) REFERENCES routes(id),
                          FOREIGN KEY (owner_account_id) REFERENCES accounts(id),
                          FOREIGN KEY (leader_account_id) REFERENCES accounts(id),
                          INDEX idx_project_status(status),
                          INDEX idx_project_departure(departure_date)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 8) 拼单成员
CREATE TABLE project_members (
                                 id BIGINT PRIMARY KEY AUTO_INCREMENT,
                                 project_id BIGINT NOT NULL,
                                 account_id BIGINT NOT NULL,
                                 member_role ENUM('OWNER','MEMBER') NOT NULL DEFAULT 'MEMBER',
                                 join_status ENUM('JOINED','QUIT','KICKED','COMPLETED') NOT NULL DEFAULT 'JOINED',
                                 joined_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                                 UNIQUE KEY uk_project_member(project_id, account_id),
                                 FOREIGN KEY (project_id) REFERENCES projects(id),
                                 FOREIGN KEY (account_id) REFERENCES accounts(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 9) 领队接单记录
CREATE TABLE leader_applications (
                                     id BIGINT PRIMARY KEY AUTO_INCREMENT,
                                     project_id BIGINT NOT NULL,
                                     leader_account_id BIGINT NOT NULL,
                                     status ENUM('PENDING','ACCEPTED','REJECTED','CANCELLED') NOT NULL DEFAULT 'PENDING',
                                     message VARCHAR(255),
                                     created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                                     updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                                     UNIQUE KEY uk_project_leader(project_id, leader_account_id),
                                     FOREIGN KEY (project_id) REFERENCES projects(id),
                                     FOREIGN KEY (leader_account_id) REFERENCES accounts(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 10) 会话（用户-领队聊天）
CREATE TABLE chat_sessions (
                               id BIGINT PRIMARY KEY AUTO_INCREMENT,
                               project_id BIGINT NOT NULL,
                               user_account_id BIGINT NOT NULL,
                               leader_account_id BIGINT NOT NULL,
                               created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                               UNIQUE KEY uk_project_chat(project_id, user_account_id, leader_account_id),
                               FOREIGN KEY (project_id) REFERENCES projects(id),
                               FOREIGN KEY (user_account_id) REFERENCES accounts(id),
                               FOREIGN KEY (leader_account_id) REFERENCES accounts(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 11) 消息
CREATE TABLE chat_messages (
                               id BIGINT PRIMARY KEY AUTO_INCREMENT,
                               session_id BIGINT NOT NULL,
                               sender_account_id BIGINT NOT NULL,
                               content TEXT NOT NULL,
                               msg_type ENUM('TEXT','IMAGE','SYSTEM') NOT NULL DEFAULT 'TEXT',
                               sent_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                               FOREIGN KEY (session_id) REFERENCES chat_sessions(id),
                               FOREIGN KEY (sender_account_id) REFERENCES accounts(id),
                               INDEX idx_msg_session_time(session_id, sent_at)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 12) 评价（用户评领队、领队评用户、路线评价）
CREATE TABLE reviews (
                         id BIGINT PRIMARY KEY AUTO_INCREMENT,
                         project_id BIGINT NOT NULL,
                         route_id BIGINT NOT NULL,
                         from_account_id BIGINT NOT NULL,
                         to_account_id BIGINT NULL,                 -- 可为空：仅路线评价
                         review_type ENUM('USER_TO_LEADER','LEADER_TO_USER','ROUTE_ONLY') NOT NULL,
                         overall_score TINYINT NOT NULL,            -- 1-5
                         content VARCHAR(500),
                         created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                         FOREIGN KEY (project_id) REFERENCES projects(id),
                         FOREIGN KEY (route_id) REFERENCES routes(id),
                         FOREIGN KEY (from_account_id) REFERENCES accounts(id),
                         FOREIGN KEY (to_account_id) REFERENCES accounts(id),
                         INDEX idx_review_to(to_account_id),
                         INDEX idx_review_route(route_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 13) 评价按 tag 打分（支持“历史路线->tag->评价”“领队->tag评分”）
CREATE TABLE review_tag_scores (
                                   review_id BIGINT NOT NULL,
                                   tag_id BIGINT NOT NULL,
                                   score TINYINT NOT NULL,                    -- 1-5
                                   PRIMARY KEY (review_id, tag_id),
                                   FOREIGN KEY (review_id) REFERENCES reviews(id),
                                   FOREIGN KEY (tag_id) REFERENCES tags(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;